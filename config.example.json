{
  "listen_addr": ":8080",
  "db_path": "./data/stats.db",
  "allowed_log_roots": ["/var/log"],
  "auth": {
    "bootstrap_admin": {
      "username": "admin",
      "password": "change-me-on-first-login"
    },
    "session_ttl_hours": 24,
    "cookie_secure": false
  },

  "_comment": "The fields below are runtime-tunable: they are only read on the very first launch (to seed the runtime_config row) and edited via the Settings panel thereafter.",
  "watch": true,
  "keywords": ["login", "admin", "api", "search"],
  "sources": [
    {
      "name": "nginx-main",
      "type": "file",
      "path": "/var/log/nginx/access.log",
      "read_compressed": false,
      "format": {
        "engine": "nginx",
        "preset": "combined"
      }
    }
  ]
}
